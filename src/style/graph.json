[
	{
		"selector": "node:active",
		"css": {
			"overlay-opacity": "0"
		}
	},
	{
		"selector": "edge",
		"css": {
			"curve-style": "bezier",
			"target-arrow-shape": "triangle"
		}
	},
	{
		"selector": "node[type=\"host\"]",
		"css": {
			"content": "data(name)",
			"shape": "hexagon",
			"width": "51",
			"height": "44",
			"background-color": "#95a5a6",
			"border-width": "3",
			"border-color": "#7f8c8d",
			"text-valign": "center",
			"text-halign": "center",
			"color": "#ffffff",
			"font-size": "11",
			"font-weight": "bold",
			"text-outline-width": "1",
			"text-outline-color": "#2c3e50",
			"text-wrap": "wrap",
			"text-max-width": "60",
			"transition-property": "background-color, border-color, border-width",
			"transition-duration": "0.2s"
		}
	},
	{
		"selector": "node[type=\"host\"][state=\"running\"]",
		"css": {
			"background-color": "#2ecc71",
			"border-color": "#27ae60"
		}
	},
	{
		"selector": "node[type=\"host\"][state=\"stopped\"]",
		"css": {
			"background-color": "#e74c3c",
			"border-color": "#c0392b"
		}
	},
	{
		"selector": "node[type=\"host\"][state=\"unhealthy\"]",
		"css": {
			"background-color": "#f39c12",
			"border-color": "#d35400"
		}
	},
	{
		"selector": "node[type=\"host\"][state=\"suspended\"]",
		"css": {
			"background-color": "#5dade2",
			"border-color": "#2e86c1"
		}
	},
	{
		"selector": "node[type=\"host\"][state=\"unknown\"]",
		"css": {
			"background-color": "#95a5a6",
			"border-color": "#7f8c8d"
		}
	},
	{
		"selector": "node[type=\"host\"]:selected",
		"css": {
			"border-width": "5",
			"border-color": "#ffffff",
			"overlay-color": "#3498db",
			"overlay-opacity": "0.25",
			"overlay-padding": "8"
		}
	},
	{
		"selector": "node[type=\"network\"]",
		"css": {
			"content": "data(name)",
			"shape": "round-rectangle",
			"background-color": "#34495e",
			"border-width": "2",
			"border-color": "#2c3e50",
			"color": "#ecf0f1",
			"font-size": "10",
			"text-valign": "center",
			"text-halign": "center",
			"text-outline-width": "2",
			"text-outline-color": "#2c3e50",
			"padding": "6"
		}
	},
	{
		"selector": "edge[type=\"l2link\"]",
		"style": {
			"target-arrow-shape": "none",
			"curve-style": "bezier",
			"width": "2",
			"line-color": "#3498db",
			"line-opacity": "0.7"
		}
	},
	{
		"selector": "edge[type=\"l7link\"]",
		"style": {
			"target-arrow-shape": "triangle",
			"target-arrow-color": "#7f8c8d",
			"curve-style": "bezier",
			"line-color": "#7f8c8d"
		}
	},
	{
		"selector": ".dimmed",
		"css": {
			"opacity": "0.2"
		}
	},
	{
		"selector": "node.highlighted",
		"css": {
			"border-width": "5",
			"border-color": "#3498db"
		}
	},
	{
		"selector": "edge.highlighted",
		"css": {
			"width": "4",
			"line-color": "#3498db",
			"line-opacity": "1",
			"target-arrow-color": "#3498db"
		}
	}
]
