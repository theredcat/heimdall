  padding: 10px 0 0 10px;
  display: block;
  font-family: monospace;
  white-space: pre;
  unicode-bidi: embed;
  overflow: auto
}
.lineprefix {
  padding: 10px 10px 0 10px;
  float: left;
  display: block;
  font-family: monospace;
}
.log-line-stdout {
  color: black;
}
.log-line-stdin {
  color: darkgreen;
}
